# ============================================
# INVENZA Backend Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ===========================================
# SUPABASE Configuration (Required)
# ===========================================
# Get these from: https://app.supabase.com -> Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ===========================================
# JWT Authentication (Required)
# ===========================================
# Secret key for signing JWT tokens - use a strong random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# Token expiration (e.g., 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# ===========================================
# Server Configuration
# ===========================================
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins (use * for all)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ===========================================
# Cloudinary Configuration (Required for Images)
# ===========================================
# Get these from: https://console.cloudinary.com/settings
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# Email Configuration (Required for Billing)
# ===========================================
# For Gmail: Use App Password (not your regular password)
# Enable 2FA and generate App Password at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Optional: Custom SMTP configuration
# If EMAIL_HOST is set, it will be used instead of Gmail
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_SERVICE=gmail

# ===========================================
# Admin Configuration
# ===========================================
# Initial admin password (used by seed script)
ADMIN_PASSWORD=your-secure-admin-password

# ===========================================
# Demo Mode (Optional)
# ===========================================
# Set to true to bypass authentication for demo purposes
DEMO_MODE=false
# DEMO_SEED=1234
